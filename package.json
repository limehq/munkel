{
	"name": "munkel",
	"private": true,
	"packageManager": "bun@1.3.9",
	"workspaces": ["apps/*"],
	"scripts": {
		"dev": "turbo dev --filter=!@munkel/macos",
		"build": "turbo build",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"deploy": "turbo deploy",
		"build:release": "scripts/build-release.sh",
		"matrix:up": "bash infra/matrix/scripts/up.sh",
		"matrix:down": "bash infra/matrix/scripts/down.sh",
		"matrix:gateway": "bash scripts/matrix-gateway.sh",
		"matrix:dev": "bash infra/matrix/scripts/up.sh && bash scripts/matrix-gateway.sh",
		"matrix:test": "bash scripts/matrix-test.sh"
	},
	"overrides": {
		"esbuild": "0.28.1"
	},
	"devDependencies": {
		"turbo": "^2.5.0"
	}
}
