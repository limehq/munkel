{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"@munkel/macos#build": {
			"cache": false
		},
		"@munkel/windows#build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "release/**"]
		},
		"@munkel/windows#dev": {
			"cache": false,
			"persistent": true
		},
		"@munkel/windows#typecheck": {
			"cache": false
		},
		"test": {},
		"typecheck": {},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"deploy": {
			"dependsOn": ["build"],
			"cache": false
		}
	}
}
