{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"],
			"env": ["VITE_PUBLIC_POSTHOG_KEY"]
		},
		"@munkel/macos#build": {
			"cache": false
		},
		"test": {},
		"typecheck": {},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"deploy": {
			"dependsOn": ["build"],
			"cache": false
		}
	}
}
