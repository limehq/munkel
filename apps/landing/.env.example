# Extra hostnames (comma-separated) the Vite dev server accepts beyond
# localhost — e.g. a LAN/mDNS name to open `bun run dev` from your phone.
# Copy to .env and set your own; consumed by vite.config.ts (server.allowedHosts).
DEV_ALLOWED_HOSTS=my-machine.local

# PostHog product analytics (landing site only). The phc_ project token is public
# by design — it ships in the client bundle. Leave unset to disable PostHog.
VITE_PUBLIC_POSTHOG_KEY=
