# DEV-ONLY config for the Munkel PoC Matrix island. Committed on purpose: this is
# a throwaway, loopback-bound homeserver for development. NEVER reuse these values
# anywhere real. The gateway and scripts source this file.
export MATRIX_BASE_URL="http://localhost:8008"
export MATRIX_SERVER_NAME="munkel.localhost"
export MATRIX_REGISTRATION_SHARED_SECRET="munkel-dev-shared-secret-change-me"
# Gateway-only secret used to derive each install's Matrix password from its
# memberId. NOT the circle code/key — it never leaves the gateway.
export MATRIX_PW_PEPPER="munkel-dev-pw-pepper-change-me"
export MATRIX_SYNAPSE_IMAGE="ghcr.io/element-hq/synapse:v1.151.0"
